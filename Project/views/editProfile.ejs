<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Profile | MovieHub</title>
  <link rel="stylesheet" href="/profile.css">
</head>
<body>
  <nav class="top-nav">
    <div class="logo">MovieHub</div>
    <div class="nav-links">
      <a href="/home">Home</a>
      <a href="/profile">Profile</a>
      <a href="/logout" class="logout-btn">Logout</a>
    </div>
  </nav>

  <main class="edit-page">
    <section class="edit-card">
      <h1>Edit Profile</h1>
      <p class="subtitle">Update your MovieHub profile details.</p>

      <% if (error) { %>
        <div class="error-box"><%= error %></div>
      <% } %>

      <form action="/profile/edit" method="POST" class="edit-form">
        <div class="input-group">
          <label for="username">Username</label>
          <input type="text" id="username" name="username" value="<%= user.username %>" required>
        </div>

        <div class="input-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" value="<%= user.email %>" required>
        </div>

        <div class="input-group">
          <label for="favouriteGenre">Favourite Genre</label>
          <input type="text" id="favouriteGenre" name="favouriteGenre" value="<%= user.favouriteGenre %>">
        </div>

        <div class="input-group">
          <label for="bio">Bio</label>
          <textarea id="bio" name="bio" rows="5"><%= user.bio %></textarea>
        </div>

        <div class="form-actions">
          <button type="submit" class="primary-btn">Save Changes</button>
          <a href="/profile" class="secondary-btn">Cancel</a>
        </div>
      </form>
    </section>
  </main>
</body>
</html>